{
  "name": "qwen-tts-api",
  "version": "1.0.0",
  "private": true,
  "description": "ElevenLabs-compatible TTS API backed by Qwen3-TTS on RunPod",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create qwen-tts-db",
    "db:migrate": "node scripts/migrate-d1.mjs",
    "db:migrate:local": "node scripts/migrate-d1.mjs --local",
    "typecheck": "tsc --noEmit",
    "tail": "wrangler tail qwen-tts-api"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250224.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.100.0"
  }
}

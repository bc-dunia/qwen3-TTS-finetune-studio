# RunPod Training Pod — Qwen3-TTS Fine-Tuning
#
# GPU pod for ephemeral training jobs. Workflow:
#   1. Pod starts with JOB_ID env var
#   2. Downloads dataset from R2
#   3. Runs prepare_data.py (audio code extraction)
#   4. Runs sft_12hz.py (full SFT training)
#   5. Uploads full checkpoints to R2 (with verification)
#   6. Updates job status and self-terminates
#
# Build (from project root):
#   docker build -f cloud/runpod/Dockerfile.training -t qwen3-tts-training .
#
# Recommended GPU: A100-40GB (1.7B) or RTX 4090 (0.6B)

FROM runpod/pytorch:1.0.3-cu1281-torch271-ubuntu2204

WORKDIR /app

# System dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends ffmpeg && \
    rm -rf /var/lib/apt/lists/*

# Python dependencies — lighter set for training (no faster-whisper/CTranslate2)
COPY cloud/runpod/requirements-training.txt /app/requirements.txt
RUN python3 -m pip install --no-cache-dir -r requirements.txt

# Copy official training scripts (from project root context)
COPY third_party/Qwen3-TTS/finetuning/ /app/finetuning/

# Copy handler code
COPY cloud/runpod/r2_storage.py /app/r2_storage.py
COPY cloud/runpod/training_handler.py /app/training_handler.py

# Pre-download tokenizer into image (required for prepare_data.py, ~200MB)
RUN HF_HUB_ENABLE_HF_TRANSFER=0 python3 -c "\
from huggingface_hub import snapshot_download; \
snapshot_download('Qwen/Qwen3-TTS-Tokenizer-12Hz', local_dir='/models/Qwen3-TTS-Tokenizer-12Hz')"

# Smoke test — validate core imports (skip faster-whisper which is not in training image)
COPY cloud/runpod/smoke_test.py /app/smoke_test.py
RUN python3 smoke_test.py

ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

CMD ["python3", "-u", "training_handler.py"]

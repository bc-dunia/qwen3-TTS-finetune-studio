# RunPod Training Pod — Qwen3-TTS Fine-Tuning (SLIM)
#
# Optimized for fast image pull on RunPod community cloud.
# Target compressed size: ~7-8GB (vs 14.5GB before).
#
# Key optimizations:
# - qwen-tts installed --no-deps (skips gradio, torchaudio, onnxruntime, sox)
# - No faster-whisper/CTranslate2 (dataset already has train_raw.jsonl)
# - No librosa (audio already 24kHz)
# - Tokenizer downloaded at runtime (not baked into image)
#
# Build (from project root):
#   docker build -f cloud/runpod/Dockerfile.training -t qwen3-tts-training .

FROM runpod/pytorch:1.0.3-cu1281-torch271-ubuntu2204

WORKDIR /app

# System dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends ffmpeg && \
    rm -rf /var/lib/apt/lists/*

# Python dependencies — minimal set
COPY cloud/runpod/requirements-training.txt /app/requirements.txt
RUN python3 -m pip install --no-cache-dir -r requirements.txt && \
    python3 -m pip install --no-cache-dir --no-deps qwen-tts>=0.1.1

# Copy official training scripts
COPY third_party/Qwen3-TTS/finetuning/ /app/finetuning/

# Copy handler code
COPY cloud/runpod/r2_storage.py /app/r2_storage.py
COPY cloud/runpod/training_handler.py /app/training_handler.py

# Smoke test — validate core imports
COPY cloud/runpod/smoke_test.py /app/smoke_test.py
RUN python3 smoke_test.py

ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

CMD ["python3", "-u", "training_handler.py"]

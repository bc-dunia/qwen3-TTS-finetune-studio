# RunPod Serverless Inference — Qwen3-TTS Voice Generation
#
# Serverless endpoint for text-to-speech generation. Features:
#   - Base model baked into image for fast cold start
#   - Downloads fine-tuned checkpoint delta from R2 on first request per voice
#   - Caches loaded models between requests (warm instances)
#   - Returns audio as base64-encoded WAV
#
# Build (from project root):
#   docker build -f cloud/runpod/Dockerfile.inference -t qwen3-tts-inference .
#
# Recommended GPU: RTX 4090 (24GB) — inference uses ~4GB VRAM

FROM runpod/pytorch:1.0.3-cu1281-torch271-ubuntu2204

WORKDIR /app

# System dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends ffmpeg && \
    rm -rf /var/lib/apt/lists/*

# Python dependencies
COPY cloud/runpod/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Pre-download base model into image (Oracle recommendation: bake base model)
# This eliminates cold-start download of ~4.5GB base model
RUN python3 -c "\
from huggingface_hub import snapshot_download; \
snapshot_download('Qwen/Qwen3-TTS-12Hz-1.7B-Base', local_dir='/models/Qwen3-TTS-12Hz-1.7B-Base'); \
snapshot_download('Qwen/Qwen3-TTS-12Hz-0.6B-Base', local_dir='/models/Qwen3-TTS-12Hz-0.6B-Base'); \
snapshot_download('Qwen/Qwen3-TTS-Tokenizer-12Hz', local_dir='/models/Qwen3-TTS-Tokenizer-12Hz')"

# Bake faster-whisper base model into the image so review ASR does not depend
# on runtime model downloads inside a short-lived worker.
RUN python3 -c "\
from faster_whisper.utils import download_model; \
download_model('base', output_dir='/models/faster-whisper-base')"

# Copy handler code
COPY cloud/runpod/r2_storage.py /app/r2_storage.py
COPY cloud/runpod/inference_handler.py /app/inference_handler.py

# Smoke test — validate all imports and system deps during build
COPY cloud/runpod/smoke_test.py /app/smoke_test.py
RUN python3 smoke_test.py

ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

# RunPod serverless entry point
CMD ["python3", "-u", "inference_handler.py"]
